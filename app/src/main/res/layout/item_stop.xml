<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <!-- Vertical Stepper / Timeline UI -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <View
            android:id="@+id/lineTop"
            android:layout_width="2dp"
            android:layout_height="16dp"
            android:background="#CCCCCC" />

        <ImageView
            android:id="@+id/dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@android:drawable/presence_online"
            app:tint="#CCCCCC" />

        <View
            android:id="@+id/lineBottom"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:minHeight="60dp"
            android:background="#CCCCCC" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="8dp"
        android:layout_marginStart="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <TextView
                android:id="@+id/stopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/pingButton"
                android:text="Village Name"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/etaValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/stopName"
                android:layout_marginTop="2dp"
                android:text="ETA: --"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/reportedByText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/etaValue"
                android:layout_marginTop="2dp"
                android:text="Source: --"
                android:textSize="11sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/pingButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:minWidth="60dp"
                android:text="PING"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <Button
                android:id="@+id/reportButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/reportedByText"
                android:layout_marginTop="4dp"
                android:text="REPORT ISSUE"
                android:textColor="#B71C1C"
                android:textSize="10sp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>